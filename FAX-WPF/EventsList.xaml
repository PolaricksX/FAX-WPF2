<Window x:Class="FAX_WPF.EventsList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FAX_WPF"
        mc:Ignorable="d"
        Title="EventsList" Height="600" Width="350"
        WindowStyle="None" AllowsTransparency="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Button Content="X"
                Style="{StaticResource GlobalRedButton}"
                Click="btnClose"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="10"/>



        <StackPanel Grid.Row="2" Orientation="Horizontal" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Margin="0,10,0,10">
            <Button Click="btnCreateCategories" Name="btnCreateCategories" 
            Width="120" Height="40"
            VerticalAlignment="Center"
            Padding="5" Margin="10,0"
            Content="New Category"/>
            <Button Click="btnCreateEvents" Name="btnCreateEvents" 
            Width="120" Height="40"
            VerticalAlignment="Center"
            Padding="5" Margin="10,0"
            Content="New Event"/>
        </StackPanel>

        <ListBox Grid.Row="1" Name="lstEvents" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" FontSize="16" Padding="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
            
        </ListBox>
    </Grid>
</Window>
