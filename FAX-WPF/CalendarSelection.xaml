<Window x:Class="FAX_WPF.CalendarSelections"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FAX_WPF"
        mc:Ignorable="d"
    Title="Calendar Selections" Height="Auto" Width="Auto" MinHeight="600" MinWidth="1000"
    WindowStartupLocation="CenterScreen"
    Background="#F3F7FB"
    WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#2F6F8F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E8EEF5" />
            <Setter Property="Foreground" Value="#45566B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#D5DFEA" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with close button -->
        <Border Grid.Row="0" Background="White" Padding="24,16" BorderBrush="#DCE5EE" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Calendar Events" FontSize="30" FontWeight="Bold" Foreground="#1E2D3D" />
                    <TextBlock Text="Review the events already stored in the selected calendar." FontSize="14" Foreground="#66788A" Margin="0,6,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="btnWindowClose_Clicked" Width="40" Height="40" 
                        Background="Transparent" Foreground="#1E2D3D" FontSize="18" FontWeight="Bold"
                        Padding="0" VerticalAlignment="Top" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24,24,24,24"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Stats Bar -->
                <Border Grid.Row="0" Background="White" CornerRadius="18" Padding="22" BorderBrush="#DCE5EE" BorderThickness="1" Margin="0,0,0,16">
                    <UniformGrid Columns="3">
                        <StackPanel>
                            <TextBlock Text="Events" FontSize="12" Foreground="#6E7F91" />
                            <TextBlock x:Name="txtEventCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#213547" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Total Duration" FontSize="12" Foreground="#6E7F91" />
                            <TextBlock x:Name="txtBusyTime" Text="0" FontSize="24" FontWeight="Bold" Foreground="#213547" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Selected Calendar" FontSize="12" Foreground="#6E7F91" />
                            <TextBlock Text="Loaded" FontSize="24" FontWeight="Bold" Foreground="#213547" />
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          x:Name="dgEvents"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          AlternatingRowBackground="#F8FBFE"
                          RowBackground="#FFFFFF"
                          FontSize="13"
                          Margin="0,0,0,16"
                          MouseDoubleClick="dgEvents_MouseDoubleClick"
                          BorderBrush="#DCE5EE"
                          BorderThickness="1"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E8EEF5"
                          MinHeight="250"
                          HorizontalAlignment="Stretch"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#E8EEF5" />
                            <Setter Property="Foreground" Value="#45566B" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderBrush" Value="#DCE5EE" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Start Date" Binding="{Binding StartDateTime, StringFormat={}{0:yyyy-MM-dd}}" Width="*" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Details}" Width="*" />
                        <DataGridTextColumn Header="Duration (min)" Binding="{Binding DurationInMinutes, StringFormat={}{0:F0}}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,48,0">
                    <Button Content="Create Category" Click="BtnCreateCategory_Click" Style="{StaticResource ActionButtonStyle}" Margin="0,0,10,0" />
                    <Button Content="Create Event" Click="BtnCreateEvent_Click" Style="{StaticResource ActionButtonStyle}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>