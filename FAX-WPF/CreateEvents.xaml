<Window x:Class="FAX_WPF.CreateEvents"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FAX_WPF"
        mc:Ignorable="d"
        Title="CreateEvents" Width="350"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height">
    <StackPanel Margin="10">
        <TextBlock Text="Calendar App" FontSize="22"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Create Event" FontSize="15"
                   HorizontalAlignment="Center"/>
        <GroupBox Header="Category">
            <StackPanel Orientation="Horizontal">
                <Label Content="Category" Margin="0, 0, 20, 0"/>
                <ComboBox x:Name="cmbCategoryName" 
                          Width="200" 
                          SelectionChanged="cmbCategoryName_SelectionChanged"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Category ID">
            <StackPanel Orientation="Horizontal">
                <Label Content="Category ID" Margin="0,0,20,0"/>
                <TextBox x:Name="txtCategoryID" Width="200"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Duration">
            <StackPanel Orientation="Horizontal">
                <Label Content="Duration" Margin="0,0,20,0"/>
                <TextBox x:Name="txtDuration" Width="200"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Date and Time">
            <StackPanel Orientation="Horizontal">
                <Label Content="Date and Time" Margin="0,0,20,0"/>
                <TextBox x:Name="txtDateTime" Width="200"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Details">
            <StackPanel Orientation="Horizontal">
                <Label Content="Details" Margin="0,0,20,0"/>
                <TextBox x:Name="txtDetails" Width="200"/>
            </StackPanel>
        </GroupBox>
        <Button Content="Save Event" Margin="10" Click="btnSave_Clicked"/>
        <Button Content="Cancel Event" Margin="10" Click="btnCancel_Clicked"/>
        <Button Content="Create Category" Margin="10" Click="btnCreateCategory_Clicked"/>
    </StackPanel>
</Window>
