<Window x:Class="FAX_WPF.CreateEvents"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FAX_WPF"
        mc:Ignorable="d"
        Title="CreateEvents" Height="450" Width="800">
    <Border Background="#336699" BorderThickness="2" Margin="20" CornerRadius="5">
        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Border Grid.ColumnSpan="2" Background="#336699" Padding="10">
                <Grid>
                    <TextBlock Text="Create Event" Foreground="White" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold"/>
                    <Button Content="X" Style="{StaticResource GlobalRedButton}" 
                     Click="btnClose" 
                     HorizontalAlignment="Right"
                     Width="25" Height="25"/>
                </Grid>
            </Border>

            <Label Content="Category ID:" Grid.Row="1" VerticalAlignment="Center" Margin="10" FontWeight="SemiBold"/>
            <TextBox Name="txtCategoryID" Grid.Row="1" Grid.Column="1" Margin="5"/>
            <Label Content="Duration in Minutes:" Grid.Row="2" VerticalAlignment="Center" Margin="10" FontWeight="SemiBold"/>
            <TextBox Name="txtDuration" Grid.Row="2" Grid.Column="1" Margin="5"/>
            <Label Content="Start DateTime:" Grid.Row="3" VerticalAlignment="Center" Margin="10" FontWeight="SemiBold"/>
            <TextBox Name="txtDateTime" Grid.Row="3" Grid.Column="1" Margin="5"/>
            <Label Content="Details:" Grid.Row="4" VerticalAlignment="Center" Margin="10" FontWeight="SemiBold"/>
            <TextBox Name="txtDetails" Grid.Row="4" Grid.Column="1" Margin="5"/>

            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal"  HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Background="DarkGreen" Content="Save" Width="80" Height="30" Margin="5"/>
                <Button Background="DarkRed" Content="Cancel" Width="80" Height="30" Margin="5"/>
                <Button Background="Aqua" Content="Create Category" Height="30" Margin="5"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
