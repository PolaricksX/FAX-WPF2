<Window x:Class="FAX_WPF.CreateEvents"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FAX_WPF"
        mc:Ignorable="d"
        Title="Create Event" Width="420" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height">
    <StackPanel Margin="12">
        <TextBlock Text="Calendar App" FontSize="22" HorizontalAlignment="Center"/>
        <TextBlock Text="Create Event" FontSize="15" HorizontalAlignment="Center"/>

        <!-- Category -->
        <GroupBox Header="Category">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" VerticalAlignment="Center">Category</Label>
                <ComboBox Grid.Column="1" x:Name="cmbCategoryName" SelectionChanged="cmbCategoryName_SelectionChanged" DisplayMemberPath="Description"/>
            </Grid>
        </GroupBox>

        <!-- Category ID -->
        <GroupBox Header="Category ID">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" VerticalAlignment="Center">Category ID</Label>
                <TextBox Grid.Column="1" x:Name="txtCategoryID"/>
            </Grid>
        </GroupBox>

        <!-- Duration -->
        <GroupBox Header="Duration (minutes)">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" VerticalAlignment="Center">Duration</Label>
                <TextBox Grid.Column="1" x:Name="txtDuration"/>
            </Grid>
        </GroupBox>

        <!-- Date and Time -->
        <GroupBox Header="Date and Time">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" VerticalAlignment="Center">Date and Time</Label>
                <TextBox Grid.Column="1" x:Name="txtDateTime"/>
            </Grid>
        </GroupBox>

        <!-- Details -->
        <GroupBox Header="Details">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" VerticalAlignment="Center">Details</Label>
                <TextBox Grid.Column="1" x:Name="txtDetails"/>
            </Grid>
        </GroupBox>

        <StackPanel Orientation="Vertical" Margin="0,6,0,0">
            <Button Content="Save Event" Click="btnSave_Clicked" Height="36" Background="#2F6F8F" Foreground="White" HorizontalAlignment="Stretch"/>
            <Button Content="Cancel Event" Click="btnCancel_Clicked" Height="36" Margin="0,8,0,0" Background="#2F6F8F" Foreground="White" HorizontalAlignment="Stretch"/>
            <Button Content="Create Category" Click="btnCreateCategory_Clicked" Height="36" Margin="0,8,0,0" Background="#2F6F8F" Foreground="White" HorizontalAlignment="Stretch"/>
        </StackPanel>
    </StackPanel>
</Window>
